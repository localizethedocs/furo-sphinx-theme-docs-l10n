#: ../../../kitchen-sink/generic.rst:166
msgid ""
"Footnotes may be numbered, either manually (as in [1]_) or automatically "
"using a \"#\"-prefixed label.  This footnote has a label so it can be "
"referred to from multiple places, both as a footnote reference ([#label]_) "
"and as a hyperlink reference (label_)."
msgstr ""

#: ../../../kitchen-sink/generic.rst:172
msgid ""
"This footnote is numbered automatically and anonymously using a label of "
"\"#\" only."
msgstr ""

#: ../../../kitchen-sink/generic.rst:175
msgid ""
"Footnotes may also use symbols, specified with a \"*\" label. Here's a "
"reference to the next footnote: [*]_."
