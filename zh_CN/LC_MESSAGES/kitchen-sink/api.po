#: ../../../kitchen-sink/api.rst:13
msgid ""
"Avoid having in-function-signature type annotations with autodoc, by setting "
"the following options:"
msgstr ""

#: ../../../kitchen-sink/api.rst:16
msgid ""
"# -- Options for autodoc "
"----------------------------------------------------\n"
"# https://www.sphinx-doc.org/en/master/usage/extensions/autodoc."
"html#configuration\n"
"\n"
"# Automatically extract typehints when specified and place them in\n"
"# descriptions of the relevant function/method.\n"
"autodoc_typehints = \"description\"\n"
"\n"
"# Don't show class signature with the class' name.\n"
"autodoc_class_signature = \"separated\""
msgstr ""

