#: ../../../kitchen-sink/blocks.rst:200
msgid ""
"from typing import Iterator\n"
"\n"
"\n"
"# This is an example\n"
"class Math:\n"
"    @staticmethod\n"
"    def fib(n: int) -> Iterator[int]:\n"
"        \"\"\"Fibonacci series up to n\"\"\"\n"
"        a, b = 0, 1\n"
"        while a < n:\n"
"            yield a\n"
"            a, b = b, a + b\n"
"\n"
"\n"
"result = sum(Math.fib(42))\n"
"print(\"The answer is {}\".format(result))"
msgstr ""

